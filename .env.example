# ─────────────────────────────────────────────────────────────────────
# WASP — environment configuration
# ─────────────────────────────────────────────────────────────────────
# `install.sh` and `wasp onboard` generate a real `.env` from this file.
# Never commit `.env` — see .gitignore.
# Secrets marked AUTO are filled with secure random values by the
# installer; do not edit unless you know what you are doing.
# ─────────────────────────────────────────────────────────────────────

# ── Core ───────────────────────────────────────────────────────────────
TIMEZONE=UTC
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────
# AUTO: 32 random hex chars
POSTGRES_PASSWORD=

# ── Dashboard ─────────────────────────────────────────────────────────
# AUTO: 64 random hex chars (HMAC signing for sessions)
DASHBOARD_SECRET=
# AUTO: 64 random hex chars (signs media URLs / chat uploads)
MEDIA_SIGNING_SECRET=
# Set during `wasp onboard`. Empty = dashboard disabled.
DASHBOARD_USER=
DASHBOARD_PASSWORD=
# Public URL for the dashboard if behind a reverse proxy. Empty = http://<host>:8080
DASHBOARD_PUBLIC_URL=
DASHBOARD_PORT=8080  # external port, default 8080
# Host interface the dashboard binds to. Default 127.0.0.1 means the
# dashboard is reachable ONLY from the host itself (use an SSH tunnel:
# `ssh -L 8080:127.0.0.1:8080 user@host`). Set to 0.0.0.0 to expose
# publicly — only do this behind a TLS reverse proxy (Caddy / nginx /
# Cloudflare Tunnel). v2.7.1 hardening, see CHANGELOG.
DASHBOARD_BIND=127.0.0.1

# ── Telegram bridge ────────────────────────────────────────────────────
# Get from @BotFather on Telegram. Empty = Telegram bot disabled.
TELEGRAM_BOT_TOKEN=
# REQUIRED if TELEGRAM_BOT_TOKEN is set: comma-separated numeric Telegram
# user IDs allowed to talk to your bot. Get yours from @userinfobot.
# Empty + token set = bot refuses to start (fail-closed — no public bot).
TELEGRAM_ALLOWED_USERS=
# Chat ID where the agent sends scheduler / health alerts. The wizard
# replicates TELEGRAM_ALLOWED_USERS here so notifications reach you.
SCHEDULER_NOTIFY_CHAT_ID=

# ── LLM providers — fill at least one ──────────────────────────────────
# Anthropic Claude (recommended for the most capable models)
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# xAI Grok
XAI_API_KEY=
# Google Gemini
GOOGLE_API_KEY=

# Default provider used by the model router when no override is given.
# Options: anthropic | openai | xai | google | local
DEFAULT_PROVIDER=anthropic

# ── Optional integrations ──────────────────────────────────────────────
# Email (SMTP) — leave blank to disable
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Gmail recipient allowlist — comma-separated emails OR @domain.com entries.
# When set, the gmail skill refuses to send to any recipient not on the list
# (defense-in-depth against prompt injection asking the agent to email
# arbitrary addresses). Empty = no allowlist (any recipient permitted).
# Example: alice@example.com,bob@example.com,@company.com
GMAIL_RECIPIENT_ALLOWLIST=

# ── Advanced ───────────────────────────────────────────────────────────
# Sovereign mode unlocks full skill round budget (12) and injects the
# operator prime block. Leave true unless debugging.
SOVEREIGN_MODE=true

# Path on the host where WASP is installed. The agent reads this so its
# self-repair commands point to the right rebuild directory. The installer
# sets this automatically. Override only if you moved the install.
WASP_HOST_DIR=/opt/wasp
